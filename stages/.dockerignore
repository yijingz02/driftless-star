# Build context is `stages/`, so all rules are relative to that.

# Pixi local environments (the build creates fresh ones; don't copy host's)
.pixi/*

# Apptainer images
*.sif

# OS / editor metadata
.DS_Store

# Python / test caches
__pycache__/
*.py[codz]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Stage runtime I/O: bind-mounted at run time, not needed in the image.
# Keeping them out of the build context keeps images small.
stage*/input/
stage*/output/
