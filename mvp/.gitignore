# pixi environments
.pixi/*
!.pixi/config.toml

# Runtime outputs (distinct from tracked expected_output/ reference fixtures)
stage*/output/

# Runtime input copies seeded from expected_input/ (populate via
# 'pixi run initialize-example-inputs' or manually)
stage*/input/

# Snakemake workflow metadata (dag cache, run history, shadow dirs)
.snakemake/
